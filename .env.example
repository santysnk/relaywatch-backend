# Plantilla de variables de entorno para el backend.
#
# Cómo usarlo:
# 1. Copiá este archivo a `.env` (en la misma carpeta `backend/`).
# 2. Reemplazá los valores de ejemplo con los reales de tu instalación local.
# 3. NO subas el `.env` al repo (ya está en `.gitignore`).

# --- Base de datos MySQL local ---
DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=root
DB_PASSWORD=tu_password_de_mysql
DB_NAME=relaywatch

# --- Servidor Nest ---
PORT=3000

# --- Autenticación (JWT) ---
# Generar un secreto random con:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=tu_secreto_jwt_generado
JWT_EXPIRES_IN=1d

# --- Frontend (para CORS) ---
# Origen del frontend autorizado a llamar a la API.
FRONTEND_URL=http://localhost:5173

