# Plantilla de variables de entorno para el backend.
#
# Cómo usarlo:
# 1. Copiá este archivo a `.env` (en la misma carpeta `backend/`).
# 2. Reemplazá los valores de ejemplo con los reales de tu instalación local.
# 3. NO subas el `.env` al repo (ya está en `.gitignore`).

# --- Base de datos MySQL local ---
DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=root
DB_PASSWORD=tu_password_de_mysql
DB_NAME=relaywatch

# --- Servidor Nest ---
PORT=3000

